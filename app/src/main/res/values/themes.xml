<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Minimal base theme for the Compose activity (Compose owns all UI theming) -->
    <style name="Theme.SmartResumeBuilder" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- Splash screen theme — transitions to base theme after splash completes -->
    <style name="Theme.SmartResumeBuilder.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartResumeBuilder</item>
    </style>

</resources>
