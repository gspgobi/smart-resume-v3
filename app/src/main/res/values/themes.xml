<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Minimal base theme for the Compose activity (Compose owns all UI theming) -->
    <style name="Theme.SmartResumeBuilder" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- ActionBar theme for CropImageActivity — app default is NoActionBar which hides the Save button -->
    <style name="Theme.SmartResumeBuilder.CropImage" parent="Theme.AppCompat.DayNight">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryDark">#1565C0</item>
        <item name="colorAccent">#1565C0</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#1565C0</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="actionBarTheme">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item>
    </style>

    <!-- Splash screen theme — transitions to base theme after splash completes -->
    <style name="Theme.SmartResumeBuilder.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartResumeBuilder</item>
    </style>

</resources>
