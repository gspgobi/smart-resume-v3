<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude DataStore preferences (contains FCM token and user flags) -->
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude DataStore preferences (contains FCM token and user flags) -->
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
